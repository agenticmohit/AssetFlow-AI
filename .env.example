ASSETFLOW_ENVIRONMENT=development
ASSETFLOW_DATABASE_URL=sqlite:///./assetflow.db
ASSETFLOW_SECRET_KEY=replace-with-a-cryptographically-random-secret-at-least-32-characters
ASSETFLOW_JWT_ALGORITHM=HS256
ASSETFLOW_ACCESS_TOKEN_TTL_MINUTES=60
ASSETFLOW_DEBUG=false
ASSETFLOW_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
ASSETFLOW_MAX_UPLOAD_BYTES=10485760
ASSETFLOW_APPROVED_PREVIEW_RETENTION_DAYS=10
ASSETFLOW_UPLOAD_DIR=var/uploads
OPENAI_API_KEY=
ASSETFLOW_OPENAI_MODEL=gpt-4o-mini
ASSETFLOW_AI_HOURLY_REQUEST_LIMIT=5
ASSETFLOW_AI_COOLDOWN_SECONDS=30
